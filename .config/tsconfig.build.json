{
  "extends": ["@tsconfig/node24", "@tsconfig/strictest"],
  "include": ["./global.d.ts", "../src/**/*"],
  "compilerOptions": {
    "types": ["node"],
    "lib": ["DOM", "ESNext"],
    "noEmit": false,
    "rootDir": "..",
    "outDir": "../dist",
    "declaration": true,
    "declarationMap": true,
    "target": "es2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "erasableSyntaxOnly": true
  }
}

{
  "extends": ["@tsconfig/node24", "@tsconfig/strictest"],
  "include": ["./global.d.ts", "../tests/**/*"],
  "exclude": ["../tests/**/*.client.test.ts", "../tests/**/*.server.test.ts"],
  "compilerOptions": {
    "types": ["node", "vite/client"],
    "lib": ["DOM", "ESNext"],
    "noEmit": true,
    "target": "es2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "erasableSyntaxOnly": true
  }
}
